rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && 
        incoming().uid == userId && 
        incoming().username is string &&
        incoming().username.size() >= 3 &&
        incoming().username.size() <= 20;
      allow update: if isOwner(userId) && 
        incoming().uid == userId &&
        incoming().username == existing().username;
    }

    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
        incoming().uid == request.auth.uid &&
        isValidId(username);
    }

    // --- Shares & Chunks ---
    match /shares/{shareId} {
      allow read: if (
        existing().recipientIds == [] || 
        request.auth.uid in existing().recipientIds || 
        existing().ownerId == request.auth.uid
      );
      
      allow create: if isSignedIn() && 
        incoming().ownerId == request.auth.uid &&
        incoming().chunkCount is number &&
        incoming().chunkCount > 0 &&
        incoming().chunkCount <= 20; // 20MB limit for safety
      
      allow update: if isOwner(existing().ownerId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['recipientIds']);

      allow delete: if isOwner(existing().ownerId) || 
        (isSignedIn() && request.auth.token.email == 'transferd001@gmail.com') ||
        (existing().expiresAt < request.time);
      
      // Chunks
      match /chunks/{chunkId} {
        allow read: if (
          get(/databases/$(database)/documents/shares/$(shareId)).data.recipientIds == [] || 
          request.auth.uid in get(/databases/$(database)/documents/shares/$(shareId)).data.recipientIds || 
          get(/databases/$(database)/documents/shares/$(shareId)).data.ownerId == request.auth.uid
        );
        allow create: if isSignedIn() && 
          get(/databases/$(database)/documents/shares/$(shareId)).data.ownerId == request.auth.uid;
        allow delete: if isSignedIn() || 
          (get(/databases/$(database)/documents/shares/$(shareId)).data.expiresAt < request.time);
      }

      // Keys
      match /keys/{userId} {
        allow read: if isOwner(userId) || 
          get(/databases/$(database)/documents/shares/$(shareId)).data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && 
          get(/databases/$(database)/documents/shares/$(shareId)).data.ownerId == request.auth.uid;
        allow delete: if isSignedIn() || 
          (get(/databases/$(database)/documents/shares/$(shareId)).data.expiresAt < request.time);
      }
    }

    // Custom Keys
    match /custom_keys/{keyId} {
      allow read: if true; // Public access for key retrieval
      allow create: if isSignedIn();
      allow delete: if isSignedIn(); 
    }
  }
}
